---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import '../../styles/global.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead title="Všechny články · Your Comfort Place" description="Procházej všechny články na blogu Your Comfort Place." />
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="logo">Your Comfort Place</a>
      <div class="nav-links">
        <a href="/">vítej</a>
        <a href="/blog" class="active">prozkoumej</a>
        <a href="/o-mne">kdo jsem</a>
      </div>
    </nav>

    <main class="section">
      <div class="label">Všechny články</div>
      <div class="grid">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="card">
            <div class="card-img" style={post.data.heroImage ? '' : 'background:#5C3520;'}>
              {post.data.heroImage
                ? <img src={post.data.heroImage.src} alt={post.data.title} style="width:100%;height:100%;object-fit:cover;" />
                : <span>{post.data.category ?? 'článek'}</span>
              }
            </div>
            <div class="card-body">
              {post.data.category && <span class="tag">{post.data.category}</span>}
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-excerpt">{post.data.description}</p>
              <p class="card-date">{formatDate(post.data.pubDate)}</p>
            </div>
          </a>
        ))}
      </div>
    </main>

    <footer class="footer">
      <span class="footer-text">© 2026 Your Comfort Place · Sabina Černá</span>
      <span class="footer-text">@cerna.sabi</span>
    </footer>
  </body>
</html>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    border-bottom: 0.5px solid var(--sb-border);
  }
  .logo { font-family: var(--font-serif); font-size: 15px; letter-spacing: 0.04em; font-weight: 400; }
  .nav-links { display: flex; gap: 28px; }
  .nav-links a { font-size: 11px; color: var(--sb-muted); }
  .nav-links a.active { color: var(--sb-brown); }

  .section { padding: 44px 32px; max-width: 1100px; margin: 0 auto; }

  .label {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sb-muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .label::after { content: ""; flex: 1; height: 0.5px; background: var(--sb-border); }

  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }

  .card {
    background: var(--sb-card);
    border: 0.5px solid var(--sb-border);
    border-radius: 3px;
    overflow: hidden;
    display: block;
  }
  .card:hover .card-title { color: var(--sb-brown); }

  .card-img {
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .card-img span { font-size: 9px; letter-spacing: 0.08em; color: rgba(234,224,208,0.2); text-transform: uppercase; }

  .card-body { padding: 18px; }

  .tag {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sb-brown);
    background: rgba(74,32,16,0.08);
    padding: 4px 10px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 10px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.4;
    color: var(--sb-text);
    font-weight: 400;
    margin-bottom: 8px;
    transition: color 0.15s;
  }
  .card-excerpt { font-size: 12px; color: var(--sb-muted); line-height: 1.6; margin-bottom: 10px; }
  .card-date { font-size: 10px; color: var(--sb-muted); }

  .footer {
    padding: 20px 32px;
    border-top: 0.5px solid var(--sb-border);
    display: flex;
    justify-content: space-between;
  }
  .footer-text { font-size: 11px; color: var(--sb-muted); }

  @media (max-width: 680px) {
    .nav { padding: 14px 16px; }
    .section { padding: 28px 16px; }
    .grid { grid-template-columns: 1fr; }
    .footer { padding: 16px; flex-direction: column; gap: 8px; }
  }
</style>
