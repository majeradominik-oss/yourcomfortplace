---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import '../../styles/global.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead title="Všechny články · Your Comfort Place" description="Procházej všechny články na blogu Your Comfort Place." />
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="logo">your comfort place</a>
      <div class="nav-links">
        <a href="/">vítej</a>
        <a href="/blog" class="active">prozkoumej</a>
        <a href="/o-mne">kdo jsem</a>
      </div>
    </nav>

    <main class="section">
      <div class="label">všechny články</div>
      <div class="grid">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="card">
            <div class="card-img">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} />
                : <span>{post.data.category ?? 'článek'}</span>
              }
            </div>
            <div class="card-body">
              {post.data.category && <span class="tag">{post.data.category}</span>}
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-excerpt">{post.data.description}</p>
              <div class="card-meta">
                <span class="card-date">{formatDate(post.data.pubDate)}</span>
                <span class="read">Číst dál ✳︎</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>

    <footer class="footer">
      <span class="footer-text">© 2026 Your Comfort Place · Sabina Černá</span>
      <a href="https://instagram.com/cerna.sabi" target="_blank" class="footer-text footer-ig">@cerna.sabi</a>
    </footer>
  </body>
</html>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
  }
  .logo { font-family: var(--font-sans); font-size: 14px; letter-spacing: 0.08em; color: var(--sb-muted); font-weight: 400; }
  .nav-links { display: flex; gap: 28px; }
  .nav-links a { font-size: 14px; color: var(--sb-muted); }
  .nav-links a.active { color: var(--sb-brown); }
  .nav-links a:hover { color: var(--sb-text); }

  .section { padding: 44px 32px; max-width: 1100px; margin: 0 auto; }

  .label {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sb-muted);
    margin-bottom: 24px;
  }

  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }

  .card {
    background: var(--sb-card);
    border: 0.5px solid var(--sb-border);
    border-radius: 3px;
    overflow: hidden;
    display: block;
  }
  .card:hover .card-title { color: var(--sb-brown); }

  .card-img {
    aspect-ratio: 3/4;
    background: #C8B9A8;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card-img span { font-size: 10px; letter-spacing: 0.08em; color: rgba(74,32,16,0.3); text-transform: uppercase; }

  .card-body { padding: 18px; }

  .tag {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sb-brown);
    background: rgba(74,32,16,0.08);
    padding: 4px 10px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 12px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 26px;
    line-height: 1.3;
    color: var(--sb-text);
    font-weight: 300;
    margin-bottom: 8px;
    transition: color 0.15s;
  }
  .card-excerpt { font-size: 15px; color: var(--sb-muted); line-height: 1.6; margin-bottom: 14px; }

  .card-meta { display: flex; justify-content: space-between; align-items: center; }
  .card-date { font-size: 12px; color: var(--sb-muted); }
  .read { font-size: 12px; letter-spacing: 0.08em; color: var(--sb-brown); }

  .footer {
    padding: 20px 32px;
    display: flex;
    justify-content: space-between;
  }
  .footer-text { font-size: 14px; color: var(--sb-muted); }
  .footer-ig:hover { color: var(--sb-brown); }

  @media (max-width: 680px) {
    .nav { padding: 12px 16px; }
    .nav-links a { font-size: 11px; }
    .logo { font-size: 11px; }
    .section { padding: 24px 16px; }
    .grid { grid-template-columns: 1fr; }
    .card-title { font-size: 22px; }
    .footer { padding: 16px; flex-direction: column; gap: 8px; }
  }
</style>
