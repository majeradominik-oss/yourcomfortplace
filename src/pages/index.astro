---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts[0];
const rest = posts.slice(1, 4);

function formatDate(date: Date) {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead title="Your Comfort Place" description="Blog Sabiny Černé." />
  </head>
  <body>
    <nav class="nav">
      <div class="logo">your comfort place</div>
      <div class="nav-links">
        <a href="/">vítej</a>
        <a href="/blog">prozkoumej</a>
        <a href="/o-mne">kdo jsem</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-inner">
        <span class="hero-star" aria-hidden="true">✳</span>
        <h1 class="hero-h1">Zpomal<br>se mnou</h1>
        <p class="hero-desc">Místo pro myšlenky, pocity, wellness a pomalé tempo.</p>
        <p class="hero-name">Sabina Černá</p>
        <a href="/blog" class="hero-cta">Prozkoumej ✳</a>
      </div>
    </section>

    <main class="section">
      {featured && (
        <>
          <div class="label">z poslední doby</div>
          <a href={`/blog/${featured.id}`} class="featured">
            <div class="feat-img">
              {featured.data.heroImage
                ? <img src={featured.data.heroImage.src} alt={featured.data.title} style="width:100%;height:100%;object-fit:cover;" />
                : <span>titulní fotka</span>
              }
            </div>
            <div class="feat-body">
              <div>
                <span class="tag">{featured.data.category ?? 'Článek'}</span>
                <h2 class="feat-title">{featured.data.title}</h2>
                <p class="feat-excerpt">{featured.data.description}</p>
              </div>
              <div class="feat-meta">
                <span class="date">{formatDate(featured.data.pubDate)}</span>
                <span class="read">Číst dál ✳</span>
              </div>
            </div>
          </a>
        </>
      )}

      {rest.length > 0 && (
        <>
          <div class="label" style="margin-top:40px;">Další články</div>
          <div class="grid">
            {rest.map(post => (
              <a href={`/blog/${post.id}`} class="card">
                <div class="card-img" style={post.data.heroImage ? '' : 'background:#C8B9A8;'}>
                  {post.data.heroImage
                    ? <img src={post.data.heroImage.src} alt={post.data.title} style="width:100%;height:100%;object-fit:cover;" />
                    : <span>{post.data.category ?? 'článek'}</span>
                  }
                </div>
                <div class="card-body">
                  <span class="tag">{post.data.category ?? 'Článek'}</span>
                  <h3 class="card-title">{post.data.title}</h3>
                  <p class="card-date">{formatDate(post.data.pubDate)}</p>
                </div>
              </a>
            ))}
          </div>
        </>
      )}
    </main>

    <footer class="footer">
      <span class="footer-text">© 2026 Your Comfort Place · Sabina Černá</span>
      <span class="footer-text">@cerna.sabi</span>
    </footer>
  </body>
</html>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    background: var(--sb);
  }
  .logo {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--sb-muted);
    font-weight: 400;
  }
  .nav-links {
    display: flex;
    gap: 28px;
  }
  .nav-links a {
    font-size: 11px;
    color: var(--sb-muted);
  }
  .nav-links a:hover { color: var(--sb-text); }

  .hero {
    padding: 64px 32px 56px;
    background: var(--sb);
  }
  .hero-inner {
    max-width: 520px;
  }
  .hero-star {
    font-size: 13px;
    color: var(--sb-muted);
    margin-bottom: 24px;
    display: block;
  }
  .hero-h1 {
    font-family: var(--font-serif);
    font-size: 64px;
    line-height: 1.05;
    color: var(--sb-text);
    font-weight: 300;
    margin: 0 0 24px;
  }
  .hero-desc {
    font-size: 13px;
    line-height: 1.7;
    color: var(--sb-muted);
    margin: 0 0 6px;
  }
  .hero-name {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--sb-mid);
    font-style: italic;
    margin: 0 0 32px;
  }
  .hero-cta {
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--sb-muted);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 20px;
    border-radius: 20px;
    border: 0.5px solid var(--sb-border);
    transition: border-color 0.15s, color 0.15s;
  }
  .hero-cta:hover { color: var(--sb-brown); border-color: var(--sb-mid); }

  .section { padding: 44px 32px; }

  .label {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sb-muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .label::after {
    content: "";
    flex: 1;
    height: 0.5px;
    background: var(--sb-border);
  }

  .featured {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    border: 0.5px solid var(--sb-border);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .feat-img {
    background: #C8B9A8;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .feat-img span {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(74, 32, 16, 0.25);
    text-transform: uppercase;
  }
  .feat-body {
    background: var(--sb-card);
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .tag {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sb-brown);
    background: rgba(74, 32, 16, 0.08);
    padding: 4px 10px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 14px;
  }
  .feat-title {
    font-family: var(--font-serif);
    font-size: 22px;
    line-height: 1.35;
    color: var(--sb-text);
    font-weight: 400;
    margin: 0 0 12px;
  }
  .feat-excerpt {
    font-size: 13px;
    line-height: 1.65;
    color: var(--sb-muted);
    margin: 0 0 20px;
  }
  .feat-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .date { font-size: 10px; color: var(--sb-muted); }
  .read {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sb-brown);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .card {
    background: var(--sb-card);
    border: 0.5px solid var(--sb-border);
    border-radius: 3px;
    overflow: hidden;
    display: block;
  }
  .card:hover .card-title { color: var(--sb-brown); }
  .card-img {
    height: 110px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .card-img span {
    font-size: 9px;
    letter-spacing: 0.08em;
    color: rgba(74, 32, 16, 0.25);
    text-transform: uppercase;
  }
  .card-body { padding: 16px; }
  .card-title {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.45;
    color: var(--sb-text);
    margin: 8px 0 6px;
    font-weight: 400;
    transition: color 0.15s;
  }
  .card-date { font-size: 10px; color: var(--sb-muted); }

  .footer {
    padding: 20px 32px;
    display: flex;
    justify-content: space-between;
  }
  .footer-text { font-size: 11px; color: var(--sb-muted); }

  @media (max-width: 680px) {
    .nav { padding: 14px 16px; }
    .hero { padding: 40px 16px 36px; }
    .hero-h1 { font-size: 44px; }
    .section { padding: 28px 16px; }
    .featured { grid-template-columns: 1fr; }
    .feat-img { min-height: 160px; }
    .grid { grid-template-columns: 1fr; }
    .footer { padding: 16px; flex-direction: column; gap: 8px; }
  }
</style>
