---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts[0];
const rest = posts.slice(1, 4);

function formatDate(date: Date) {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead title="Your Comfort Place" description="Blog Sabiny Černé." />
  </head>
  <body>
    <nav class="nav">
      <div class="logo">your comfort place</div>
      <div class="nav-links">
        <a href="/">vítej</a>
        <a href="/blog">prozkoumej</a>
        <a href="/o-mne">kdo jsem</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-inner">
        <span class="hero-star" aria-hidden="true">✳</span>
        <h1 class="hero-h1">Zpomal<br>se mnou</h1>
        <p class="hero-desc">Místo pro myšlenky, pocity, wellness a pomalé tempo.</p>
        <p class="hero-name">Sabina Černá</p>
        <a href="/blog" class="hero-cta">Prozkoumej ✳</a>
      </div>
    </section>

    <main class="section">
      <div class="label">z poslední doby</div>
      <div class="grid">
        {posts.slice(0, 3).map((post) => (
          <a href={`/blog/${post.id}`} class="card">
            <div class="card-img">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} />
                : <span>{post.data.category ?? 'článek'}</span>
              }
            </div>
            <div class="card-body">
              <span class="tag">{post.data.category ?? 'Článek'}</span>
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-excerpt">{post.data.description}</p>
              <div class="card-meta">
                <span class="date">{formatDate(post.data.pubDate)}</span>
                <span class="read">Číst dál ✳</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>

    <footer class="footer">
      <span class="footer-text">© 2026 Your Comfort Place · Sabina Černá</span>
      <a href="https://instagram.com/cerna.sabi" target="_blank" class="footer-text footer-ig">@cerna.sabi</a>
    </footer>
  </body>
</html>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    background: var(--sb);
  }
  .logo {
    font-family: var(--font-sans);
    font-size: 14px;
    letter-spacing: 0.08em;
    color: var(--sb-muted);
    font-weight: 400;
  }
  .nav-links {
    display: flex;
    gap: 28px;
  }
  .nav-links a {
    font-size: 14px;
    color: var(--sb-muted);
  }
  .nav-links a:hover { color: var(--sb-text); }

  .hero {
    padding: 64px 32px 56px;
    background: var(--sb);
  }
  .hero-inner {
    max-width: 520px;
  }
  .hero-star {
    font-size: 26px;
    color: var(--sb-muted);
    margin-bottom: 28px;
    display: block;
  }
  .hero-h1 {
    font-family: var(--font-serif);
    font-size: 90px;
    line-height: 1.05;
    color: var(--sb-text);
    font-weight: 300;
    margin: 0 0 24px;
  }
  .hero-desc {
    font-size: 18px;
    line-height: 1.7;
    color: var(--sb-muted);
    margin: 0 0 6px;
  }
  .hero-name {
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--sb-muted);
    font-style: normal;
    font-weight: 300;
    margin: 0 0 32px;
  }
  .hero-cta {
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--sb-muted);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 24px;
    border-radius: 20px;
    border: 0.5px solid var(--sb-border);
    transition: border-color 0.15s, color 0.15s;
  }
  .hero-cta:hover { color: var(--sb-brown); border-color: var(--sb-mid); }

  .section { padding: 44px 32px; }

  .label {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sb-muted);
    margin-bottom: 24px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .card {
    background: var(--sb-card);
    border: 0.5px solid var(--sb-border);
    border-radius: 3px;
    overflow: hidden;
    display: block;
  }
  .card:hover .card-title { color: var(--sb-brown); }

  .card-img {
    aspect-ratio: 3/4;
    background: #C8B9A8;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-img span {
    font-size: 9px;
    letter-spacing: 0.08em;
    color: rgba(74, 32, 16, 0.3);
    text-transform: uppercase;
  }

  .card-body { padding: 18px; }

  .tag {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sb-brown);
    background: rgba(74, 32, 16, 0.08);
    padding: 4px 10px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 12px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 26px;
    line-height: 1.3;
    color: var(--sb-text);
    font-weight: 300;
    margin: 0 0 8px;
    transition: color 0.15s;
  }

  .card-excerpt {
    font-size: 15px;
    line-height: 1.6;
    color: var(--sb-muted);
    margin: 0 0 16px;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .date { font-size: 12px; color: var(--sb-muted); }
  .read {
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--sb-brown);
  }

  .footer {
    padding: 20px 32px;
    display: flex;
    justify-content: space-between;
  }
  .footer-text { font-size: 14px; color: var(--sb-muted); }
  .footer-ig:hover { color: var(--sb-brown); }

  @media (max-width: 680px) {
    .nav { padding: 14px 16px; }
    .hero { padding: 40px 16px 36px; }
    .hero-h1 { font-size: 44px; }
    .section { padding: 28px 16px; }
    .article-row,
    .article-row.reverse { grid-template-columns: 1fr; gap: 20px; }
    .article-row.reverse .article-img { order: 0; }
    .article-row.reverse .article-body { order: 1; padding-right: 0; }
    .article-img { max-width: 100%; aspect-ratio: 4/3; }
    .article-body { padding-left: 0; }
    .article-title { font-size: 22px; }
    .footer { padding: 16px; flex-direction: column; gap: 8px; }
  }
</style>
