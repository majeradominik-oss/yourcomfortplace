---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts[0];
const rest = posts.slice(1, 4);

function formatDate(date: Date) {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead title="Your Comfort Place" description="Bezpečné místo pro citlivé duše." />
  </head>
  <body>
    <nav class="nav">
      <div class="logo">Your Comfort Place</div>
      <div class="nav-links">
        <a href="/">vítej</a>
        <a href="/blog">prozkoumej</a>
        <a href="/o-mne">kdo jsem</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-overlay"></div>
      <div class="hero-inner">
        <span class="hero-star" aria-hidden="true">✳ &nbsp; ✳ &nbsp; ✳</span>
        <p class="hero-sub">Bezpečné místo pro citlivé duše</p>
        <h1 class="hero-h1">Zpomal<br>se mnou.</h1>
        <p class="hero-desc">Místo pro myšlenky, pocity, wellness a pomalé tempo.</p>
        <a href="/blog" class="hero-cta">Prozkoumej →</a>
      </div>
    </section>

    <main class="section">
      {featured && (
        <>
          <div class="label">Nejnovější</div>
          <a href={`/blog/${featured.id}`} class="featured">
            <div class="feat-img">
              {featured.data.heroImage
                ? <img src={featured.data.heroImage.src} alt={featured.data.title} style="width:100%;height:100%;object-fit:cover;" />
                : <span>titulní fotka</span>
              }
            </div>
            <div class="feat-body">
              <div>
                <span class="tag">{featured.data.category ?? 'Článek'}</span>
                <h2 class="feat-title">{featured.data.title}</h2>
                <p class="feat-excerpt">{featured.data.description}</p>
              </div>
              <div class="feat-meta">
                <span class="date">{formatDate(featured.data.pubDate)}</span>
                <span class="read">Číst dál →</span>
              </div>
            </div>
          </a>
        </>
      )}

      {rest.length > 0 && (
        <>
          <div class="label" style="margin-top:40px;">Další články</div>
          <div class="grid">
            {rest.map(post => (
              <a href={`/blog/${post.id}`} class="card">
                <div class="card-img" style={post.data.heroImage ? '' : 'background:#5C3520;'}>
                  {post.data.heroImage
                    ? <img src={post.data.heroImage.src} alt={post.data.title} style="width:100%;height:100%;object-fit:cover;" />
                    : <span>{post.data.category ?? 'článek'}</span>
                  }
                </div>
                <div class="card-body">
                  <span class="tag">{post.data.category ?? 'Článek'}</span>
                  <h3 class="card-title">{post.data.title}</h3>
                  <p class="card-date">{formatDate(post.data.pubDate)}</p>
                </div>
              </a>
            ))}
          </div>
        </>
      )}
    </main>

    <footer class="footer">
      <span class="footer-text">© 2026 Your Comfort Place · Sabina Černá</span>
      <span class="footer-text">@cerna.sabi</span>
    </footer>
  </body>
</html>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    background: var(--sb);
    border-bottom: 0.5px solid var(--sb-border);
  }
  .logo {
    font-family: var(--font-serif);
    font-size: 15px;
    letter-spacing: 0.04em;
    color: var(--sb-text);
    font-weight: 400;
  }
  .nav-links {
    display: flex;
    gap: 28px;
  }
  .nav-links a {
    font-size: 11px;
    color: var(--sb-muted);
  }
  .nav-links a:hover { color: var(--sb-text); }

  .hero {
    position: relative;
    min-height: 340px;
    display: flex;
    align-items: flex-end;
    padding: 52px 32px 48px;
    overflow: hidden;
    background: #2C1506 center top / cover no-repeat;
    background-image: var(--hero-image, none);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 10, 4, 0.55);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 520px;
  }
  .hero-star {
    font-size: 13px;
    color: rgba(234, 224, 208, 0.4);
    margin-bottom: 20px;
    display: block;
    letter-spacing: 0.5em;
  }
  .hero-sub {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(234, 224, 208, 0.45);
    margin-bottom: 18px;
  }
  .hero-h1 {
    font-family: var(--font-serif);
    font-size: 52px;
    line-height: 1.08;
    color: #EAE0D0;
    font-weight: 300;
    margin: 0 0 22px;
  }
  .hero-desc {
    font-size: 13px;
    line-height: 1.7;
    color: rgba(234, 224, 208, 0.6);
    margin: 0 0 28px;
  }
  .hero-cta {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(234, 224, 208, 0.7);
    border: 0.5px solid rgba(234, 224, 208, 0.35);
    padding: 10px 22px;
    display: inline-block;
    border-radius: 2px;
  }
  .hero-cta:hover { color: #EAE0D0; border-color: rgba(234, 224, 208, 0.6); }

  .section { padding: 44px 32px; }

  .label {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sb-muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .label::after {
    content: "";
    flex: 1;
    height: 0.5px;
    background: var(--sb-border);
  }

  .featured {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    border: 0.5px solid var(--sb-border);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .feat-img {
    background: #5C3A20;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .feat-img span {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(234, 224, 208, 0.2);
    text-transform: uppercase;
  }
  .feat-body {
    background: var(--sb-card);
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .tag {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sb-brown);
    background: rgba(74, 32, 16, 0.08);
    padding: 4px 10px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 14px;
  }
  .feat-title {
    font-family: var(--font-serif);
    font-size: 22px;
    line-height: 1.35;
    color: var(--sb-text);
    font-weight: 400;
    margin: 0 0 12px;
  }
  .feat-excerpt {
    font-size: 13px;
    line-height: 1.65;
    color: var(--sb-muted);
    margin: 0 0 20px;
  }
  .feat-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .date { font-size: 10px; color: var(--sb-muted); }
  .read {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sb-brown);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .card {
    background: var(--sb-card);
    border: 0.5px solid var(--sb-border);
    border-radius: 3px;
    overflow: hidden;
    display: block;
  }
  .card:hover .card-title { color: var(--sb-brown); }
  .card-img {
    height: 110px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .card-img span {
    font-size: 9px;
    letter-spacing: 0.08em;
    color: rgba(234, 224, 208, 0.2);
    text-transform: uppercase;
  }
  .card-body { padding: 16px; }
  .card-title {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.45;
    color: var(--sb-text);
    margin: 8px 0 6px;
    font-weight: 400;
    transition: color 0.15s;
  }
  .card-date { font-size: 10px; color: var(--sb-muted); }

  .footer {
    padding: 20px 32px;
    border-top: 0.5px solid var(--sb-border);
    display: flex;
    justify-content: space-between;
  }
  .footer-text { font-size: 11px; color: var(--sb-muted); }

  @media (max-width: 680px) {
    .nav { padding: 14px 16px; }
    .hero { padding: 40px 16px 36px; }
    .hero-h1 { font-size: 36px; }
    .section { padding: 28px 16px; }
    .featured { grid-template-columns: 1fr; }
    .feat-img { min-height: 160px; }
    .grid { grid-template-columns: 1fr; }
    .footer { padding: 16px; flex-direction: column; gap: 8px; }
  }
</style>
