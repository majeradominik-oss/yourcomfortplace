---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, heroImage, category } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<html lang="cs">
  <head>
    <BaseHead title={`${title} · Your Comfort Place`} description={description} />
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="logo">Your Comfort Place</a>
      <div class="nav-links">
        <a href="/">vítej</a>
        <a href="/blog">prozkoumej</a>
        <a href="/o-mne">kdo jsem</a>
      </div>
    </nav>

    <main class="post-main">
      {heroImage && (
        <div class="post-hero">
          <img src={heroImage} alt={title} style="width:100%;height:100%;object-fit:cover;" />
        </div>
      )}
      <article class="post-article">
        <header class="post-header">
          {category && <span class="tag">{category}</span>}
          <h1 class="post-title">{title}</h1>
          <p class="post-date">{formatDate(pubDate)}</p>
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>
      <div class="back-wrap">
        <a href="/blog" class="back">← Zpět na všechny články</a>
      </div>
    </main>

    <footer class="footer">
      <span class="footer-text">© 2026 Your Comfort Place · Sabina Černá</span>
      <span class="footer-text">@cerna.sabi</span>
    </footer>
  </body>
</html>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    border-bottom: 0.5px solid var(--sb-border);
  }
  .logo {
    font-family: var(--font-serif);
    font-size: 15px;
    letter-spacing: 0.04em;
    font-weight: 400;
  }
  .nav-links { display: flex; gap: 28px; }
  .nav-links a { font-size: 11px; color: var(--sb-muted); }

  .post-main { max-width: 720px; margin: 0 auto; padding: 48px 32px 64px; }

  .post-hero {
    width: 100%;
    height: 360px;
    overflow: hidden;
    border-radius: 3px;
    margin-bottom: 40px;
  }

  .post-header { margin-bottom: 32px; }

  .tag {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sb-brown);
    background: rgba(74, 32, 16, 0.08);
    padding: 4px 10px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 16px;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 40px;
    line-height: 1.15;
    font-weight: 300;
    color: var(--sb-text);
    margin-bottom: 12px;
  }

  .post-date { font-size: 11px; color: var(--sb-muted); }

  .prose {
    font-size: 15px;
    line-height: 1.85;
    color: var(--sb-text);
  }
  .prose p { margin-bottom: 1.4em; }
  .prose h2 {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    margin: 2em 0 0.6em;
  }
  .prose h3 {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 400;
    margin: 1.6em 0 0.5em;
  }
  .prose blockquote {
    border-left: 2px solid var(--sb-border);
    padding-left: 20px;
    color: var(--sb-muted);
    font-style: italic;
    margin: 1.5em 0;
  }

  .back-wrap { margin-top: 48px; padding-top: 24px; border-top: 0.5px solid var(--sb-border); }
  .back { font-size: 11px; letter-spacing: 0.08em; color: var(--sb-muted); }
  .back:hover { color: var(--sb-brown); }

  .footer {
    padding: 20px 32px;
    border-top: 0.5px solid var(--sb-border);
    display: flex;
    justify-content: space-between;
  }
  .footer-text { font-size: 11px; color: var(--sb-muted); }

  @media (max-width: 680px) {
    .nav { padding: 14px 16px; }
    .post-main { padding: 28px 16px 48px; }
    .post-title { font-size: 28px; }
  }
</style>
